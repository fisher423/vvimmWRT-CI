# jdcloud_re-ss-01 Device Configuration
# Target Platform
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y

# Device Profile
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y

# Device Specific Package (Wireless Firmware)
CONFIG_PACKAGE_ipq-wirmware-jdcloud_re-ss-01=y

# Base Packages
